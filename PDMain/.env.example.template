# Paws Pendragon - ToonTown Attendant
# Full documentation of every available configuration variable.
# Copy this file to .env and fill in your values.
# Keep secrets (DISCORD_TOKEN) only in .env — never in this file.
###
###
###
# ─── TTR API USER AGENT ───
# Descriptive User-Agent sent to the TTR API (they request a contact string).
USER_AGENT=Paws Pendragon-DiscBot (contact: your-email@example.com)
###
###
###
# ─── BOT TOKEN ───
# Bot token from https://discord.com/developers/applications → Bot → Token
# Never commit or share this value.
DISCORD_TOKEN=your-bot-token-here
###
###
###
# ─── GUILD ALLOW LIST ───
# Comma-separated Discord server (guild) IDs the bot is allowed to join.
# Any server NOT in this list is auto-left the moment the bot is invited.
# Servers can also be added at runtime via the Cybrancee console without
# editing this file (added IDs are persisted to state.json).
#
# How to find a Guild ID:
#   Right-click a server icon in Discord → Copy Server ID
#   (requires Developer Mode: Settings → Advanced → Developer Mode)
#
# Example with two servers:
#   GUILD_ALLOWLIST=111111111111111111,222222222222222222
GUILD_ALLOWLIST=000000000000000000
###
###
###
# ─── BOT ADMIN LIST ───
# Comma-separated Discord user IDs allowed to run bot-admin console commands:
#   stop        -- Notify all servers and shut the bot down.
#   restart     -- Notify all servers and hot-restart the process.
#   maintenance -- Toggle the maintenance-mode banner in all channels.
#   announce    -- Broadcast a message to every tracked server (auto-deletes in 30 min).
#
# How to find a User ID:
#   Right-click your user avatar in Discord → Copy User ID
#   (requires Developer Mode: Settings → Advanced → Developer Mode)
#
# Example with two admins:
#   BOT_ADMIN_IDS=310233741354336257,1043328540998897744
BOT_ADMIN_IDS=000000000000000000
###
###
###
# ─── BANED USERS LIST ───
# Comma-separated Discord user IDs that are banned from using the bot.
# Read at startup and merged into banned_users.json. Updated automatically
# when bans are added or removed via commands.
BANNED_USER_IDS=00000000000
###
###
###
# ─── QUARANTINED GUILDS LIST ───
# Comma-separated Discord guild IDs that are currently quarantined.
# Read at startup and merged into state.json. Updated automatically
# when quarantine is applied or lifted.
QUARANTINED_GUILD_IDS=0000000000
###
###
###
# ─── Refresh Interval ───
# How often (seconds) to refresh the live feed channels.
# The TTR APIs update every ~10s server-side; 60–90s avoids Discord rate limits.
REFRESH_INTERVAL=120
###
###
###
###
###
# ─── CHANNEL CATEGORY \ CHANNELS ───────────────────────────────────────────────────────────
###
# ─── CATEGORY ───
# Name of the Discord category the bot creates to house its channels.
CHANNEL_CATEGORY=PendragonTTR
###
# ─── CHANNELS ───
###
# ─── Server Update Info ───
# Combined district / invasion / field-office / Silly Meter live feed channel.
CHANNEL_INFORMATION=tt-info
###
# ─── DOODLES ───
# Doodle trait guide and live ratings feed channel (updates every 12 hours).
CHANNEL_DOODLES=tt-doodles
###
# ─── CALCULATOR ───
# Static suit-calculator info channel (use /calculate here).
CHANNEL_SUIT_CALCULATOR=suit-calc
###
###
###
###
