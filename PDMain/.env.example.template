PENDRAGON_EMOJI=<:Pendragon:1499923320613896282>
PurpleBlueCircle_EMOJI=<:PurpleBlueCircle:1499922543396519956>
PurpleGldDiamond_EMOJI=<:PurpleGldDiamond:1499922496231571657>
PurpleRDiamond_EMOJI=<:PurpleRDiamond:1499921992906706988>
LAV_Emoji=<:Lav:1499503216084390019>
TU_EMOJI=<:ToonUp:1499440893479092284>
TRAP_EMOJI=<:Trap:1499440908884643942>
LURE_EMOJI=<:Lure:1499440906170925066>
