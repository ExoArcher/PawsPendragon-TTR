# Paws Pendragon — Example Environment
#
# Copy this file to .env and fill in your real values.
# SAFE TO COMMIT: only contains placeholder values — no real secrets here.

# ─── REQUIRED ────────────────────────────────────────────────────────────────

# Bot token from https://discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=your-bot-token-here

# Discord server (guild) IDs the bot is allowed to operate in.
# The bot auto-leaves any server not listed here.
GUILD_ALLOWLIST=000000000000000000

# Discord user IDs that can run bot-admin console commands (stop, restart, announce, etc.)
BOT_ADMIN_IDS=000000000000000000

# ─── OPTIONAL ────────────────────────────────────────────────────────────────

# Seconds between live feed refreshes (60–90s recommended).
REFRESH_INTERVAL=90

# Descriptive User-Agent sent to the TTR API (they request one).
USER_AGENT=Paws Pendragon-DiscBot (contact: your-email@example.com)

# ─── CHANNEL NAMES ───────────────────────────────────────────────────────────

# Name of the Discord category the bot creates.
CHANNEL_CATEGORY=Toontown Rewritten

# Live district/invasion/field-office/Silly Meter feed channel.
CHANNEL_INFORMATION=tt-information

# Live doodle trait guide and ratings feed channel.
CHANNEL_DOODLES=tt-doodles

# Static suit-calculator info channel.
CHANNEL_SUIT_CALCULATOR=suit-calculator

# ─── CUSTOM EMOJIS ───────────────────────────────────────────────────────────

# Shown next to jellybean costs in doodle listings.
JELLYBEAN_EMOJI=<:Jellybeans:1496983830106603551>

# Shown next to districts with an active cog invasion.
COG_EMOJI=<:Cog:1496996533432877078>

# Shown next to districts immune to Mega Invasions.
SAFE_EMOJI=<:Safe:1497311481711165625>

# Infinity symbol used as the Kaboomberg annex placeholder.
INFINITE_EMOJI=♾️

# Doodle trait-tier star emojis (best → worst).
# Perfect and Amazing share the same star — the tier label tells them apart.
STAR_PERFECT=<:RBStar:1497375968619135076>
STAR_AMAZING=<:RBStar:1497375968619135076>
STAR_GREAT=<:GoldenStar:1497383695781462016>
STAR_GOOD=<:SilverStar:1497299363590967549>
STAR_OK=<:BronzeStar:1497300707554889891>
STAR_BAD=<:Trash:1497379832865226844>

# ─── BAN / QUARANTINE ────────────────────────────────────────────────────────

# Comma-separated Discord user IDs that are banned from using the bot.
# Read at startup and merged into banned_users.json. Updated automatically
# when bans are added or removed via commands.
BANNED_USER_IDS=

# Comma-separated Discord guild IDs that are currently quarantined.
# Read at startup and merged into state.json. Updated automatically
# when quarantine is applied or lifted.
QUARANTINED_GUILD_IDS=
