# Copy this file to .env and fill in your values.
# IMPORTANT: Put your real token in .env (NOT in this file). .env.example
# should only contain placeholder values — it's safe to share or commit.

# --- REQUIRED ---
# The bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here

# Comma- or space-separated list of Discord server (guild) IDs the bot
# is allowed to operate in. Any guild NOT in this list is auto-left
# the moment the bot is invited — so a stolen invite link can't drag
# the bot into a random server.
#
# Right-click a server icon in Discord -> "Copy Server ID" to grab one
# (requires Developer Mode under Settings -> Advanced).
#
# Example with two servers:
#   GUILD_ALLOWLIST=111111111111111111,222222222222222222
GUILD_ALLOWLIST=000000000000000000

# Comma- or space-separated list of Discord USER IDs allowed to run the
# bot-owner-only admin commands:
#   /laq_announce      — broadcast a message to every tracked server
#                        (auto-deletes after 30 minutes; orphaned posts
#                        are cleaned on the bot's next startup).
#   /laq_guild_add     — add a server to the allowlist at runtime
#                        without editing this file or restarting.
#   /laq_guild_remove  — remove a server from the runtime allowlist;
#                        the bot will leave that server. (Servers
#                        listed in GUILD_ALLOWLIST above can only be
#                        removed by editing this file and restarting.)
#
# Right-click your own user avatar in Discord -> "Copy User ID" to grab
# this (requires Developer Mode under Settings -> Advanced).
#
# Example with two owners:
#   BOT_OWNER_IDS=310233741354336257,1043328540998897744
BOT_OWNER_IDS=

# --- OPTIONAL ---
# How often (seconds) to refresh each channel. The TTR APIs only update
# every ~10s server-side, so 60s is a safe default that avoids
# Discord's per-channel edit rate limits.
REFRESH_INTERVAL=60

# Descriptive User-Agent sent to the TTR API (they ask for this)
USER_AGENT=ttr-discord-bot (contact: your-email@example.com)

# Channel names the bot will create / use. Change if you like.
# "information" combines invasions + population + field offices.
CHANNEL_INFORMATION=tt-information
CHANNEL_DOODLES=tt-doodles


# Custom Discord emojis. Must live in a server the bot has joined
# (Discord enforces that). Format: <:NAME:ID>  (or <a:NAME:ID> animated)
JELLYBEAN_EMOJI=<:Jellybeans:1496983830106603551>
COG_EMOJI=<:Cog:1496996533432877078>

# Shown next to districts that are immune to Mega Invasions
# (Blam Canyon, Gulp Gulch, Whoosh Rapids, Zapwood, Welcome Valley).
SAFE_EMOJI=<:Safe:1497311481711165625>

# Doodle trait-tier star emojis. Shown in the doodle list, one per
# trait slot, and in the Trait Guide embed. Tiers (best -> worst):
#   Perfect = Rarely Tired in slot #1
#   Amazing = Rarely Tired in any other slot
#   Great   = Always Affectionate/Playful + all Rarely positives
#   Good    = Often Affectionate/Playful, Pretty Calm/Excitable
#   OK      = Rarely Affectionate/Playful + all Sometimes traits
#   Bad     = every Always/Often negative trait
#
# Perfect and Amazing share the same emoji (RBStar) by default — the
# tier label box ("[Perfect]" vs "[Amazing]") tells the two apart.
STAR_PERFECT=<:RBStar:1497375968619135076>
STAR_AMAZING=<:RBStar:1497375968619135076>
STAR_GREAT=<:GoldenStar:1497383695781462016>
STAR_GOOD=<:SilverStar:1497299363590967549>
STAR_OK=<:BronzeStar:1497300707554889891>
STAR_BAD=<:Trash:1497379832865226844>

# Used as the "annexes remaining" placeholder for the hidden Kaboomberg
# field office, and anywhere else we want to render an infinity glyph.
# Override with a custom emoji (e.g. <:Infinite:123>) if you have one.
INFINITE_EMOJI=♾️
