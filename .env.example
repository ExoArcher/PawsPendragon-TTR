# LanceAQuack — local .env
#
# IMPORTANT: this file holds secrets. .gitignore already excludes it.
#            Never commit it, never paste it into a chat or screenshot.
#
# ⚠️  YOUR PREVIOUS TOKEN WAS EXPOSED AND HAS BEEN REMOVED.
#     Go to https://discord.com/developers/applications → Bot → Reset Token
#     and paste the new token below before running the bot.

# --- REQUIRED ---
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=00000000000000000000000000

# Servers the bot is allowed to operate in. Comma-separated.
GUILD_ALLOWLIST=1478614988582027317, 1475874602289991794


# --- OPTIONAL ---
# Seconds between refreshes. The TTR APIs cache ~10s server-side and
# Discord rate-limits per-channel edits, so 60–90s is the sweet spot.
REFRESH_INTERVAL=20

# Descriptive User-Agent the TTR API maintainers ask for.
USER_AGENT=LanceAQuack-DiscBot (contact: Exokidtm@gmail.com)

# Channel names the bot will create / use.
CHANNEL_INFORMATION=tt-information
CHANNEL_DOODLES=tt-doodles

# --- Custom emojis (optional) ---
# These default to the IDs the bot ships with. Override only if you've
# uploaded your own emojis with different IDs.
JELLYBEAN_EMOJI=<:Jellybeans:1496983830106603551>
COG_EMOJI=<:Cog:1496996533432877078>
SAFE_EMOJI=<:Safe:1497311481711165625>

STAR_PERFECT=<:RBStar:1497375968619135076>
STAR_AMAZING=<:RBStar:1497375968619135076>
STAR_GREAT=<:GoldenStar:1497383695781462016>
STAR_GOOD=<:SilverStar:1497299363590967549>
STAR_OK=<:BronzeStar:1497300707554889891>
STAR_BAD=<:Trash:1497379832865226844>
